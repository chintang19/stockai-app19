const Sparkline=({data,positive,width=80,height=28})=>{
  if(!data||data.length<2)return null;
  const min=Math.min(...data),max=Math.max(...data),range=max-min||1;
  const pts=data.map((v,i)=>`${(i/(data.length-1))*width},${height-((v-min)/range)*height}`).join(" ");
  return<svg width={width} height={height} style={{overflow:"visible"}}><polyline points={pts} fill="none" stroke={positive?"#22d3a0":"#f87171"} strokeWidth="1.5" strokeLinejoin="round"/></svg>;
};

