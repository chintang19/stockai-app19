                const spark=sparklines.current[ticker]||[];
                return(
                  <div key={ticker} className="card-hover" style={{background:"#0d1326",border:`1px solid ${inWatch?"#6366f1":"#1a2238"}`,borderRadius:12,padding:"13px 14px",cursor:"pointer",animation:"fadein 0.3s ease"}} onClick={()=>{setSelected(ticker);setView("main");setActiveTab("chat");}}>
                    <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start"}}>
                      <div style={{flex:1,marginRight:8}}>
                        <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:2}}>
                          <span style={{fontSize:14,fontWeight:700}}>{ticker}</span>
                          <span style={{fontSize:9,background:`${CATS[u.cat]?.color||"#6366f1"}22`,color:CATS[u.cat]?.color||"#6366f1",padding:"1px 6px",borderRadius:10,fontWeight:600}}>{CATS[u.cat]?.emoji} {u.sector}</span>
                        </div>
                        <div style={{fontSize:10,color:"#475569"}}>{u.name}</div>
                      </div>
                      <div style={{textAlign:"right",flexShrink:0}}>
                        <div style={{fontSize:15,fontWeight:700,fontFamily:"'DM Mono'"}}>${d.price?.toFixed(2)}</div>
                        <div style={{fontSize:10,color:pos?"#22d3a0":"#f87171",fontFamily:"'DM Mono'"}}>{pos?"▲":"▼"} {Math.abs(d.changePct||0).toFixed(2)}%</div>
                      </div>
                    </div>
                    <div style={{margin:"8px 0 4px"}}>{spark.length>1&&<Sparkline data={spark} positive={pos} width={280} height={28}/>}</div>
                    <div style={{fontSize:10,color:"#64748b",lineHeight:1.4,marginBottom:8}}>{u.why.slice(0,90)}...</div>
                    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                      <div style={{display:"flex",gap:5}}>
                        <span style={{fontSize:9,background:`${RATING_COLOR[u.rating]||"#6366f1"}22`,color:RATING_COLOR[u.rating]||"#6366f1",padding:"2px 6px",borderRadius:4,fontWeight:700}}>{u.rating}</span>
                        <span style={{fontSize:9,background:`${RISK_COLOR[u.risk]}22`,color:RISK_COLOR[u.risk],padding:"2px 6px",borderRadius:4,fontWeight:600}}>Risk: {u.risk}</span>
                      </div>
                      <button onClick={e=>{e.stopPropagation();inWatch?removeFromWatchlist(ticker):addToWatchlist(ticker);}} className="btn-hover" style={{fontSize:10,fontWeight:600,padding:"3px 10px",borderRadius:6,border:"none",cursor:"pointer",background:inWatch?"rgba(248,113,113,0.15)":"rgba(34,211,160,0.15)",color:inWatch?"#f87171":"#22d3a0",transition:"all 0.15s"}}>
                        {inWatch?"− Remove":"+ Watchlist"}
                      </button>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      )}

      {/* ── MAIN VIEW ── */}
      {view==="main"&&(
        <div style={{flex:1,display:"flex",overflow:"hidden"}}>
          {/* Sidebar */}
          <div style={{width:215,background:"#0a0e1a",borderRight:"1px solid #1a2238",display:"flex",flexDirection:"column",overflow:"hidden",flexShrink:0}}>
            <div style={{padding:"10px 13px 5px",fontSize:9,color:"#334155",fontWeight:700,letterSpacing:"1.5px",fontFamily:"'DM Mono'"}}>MY WATCHLIST</div>
            <div style={{flex:1,overflowY:"auto"}}>
              {watchlist.map(ticker=>{
                const d=prices[ticker]||{price:UNIVERSE[ticker]?.seed||0,change:0,changePct:0};
                const u=UNIVERSE[ticker]||{};
                const pos=(d.changePct||0)>=0;
                const spark=sparklines.current[ticker]||[];
                return(
                  <div key={ticker} className="stock-row" onClick={()=>setSelected(ticker)} style={{padding:"9px 13px",cursor:"pointer",background:selected===ticker?"rgba(99,102,241,0.12)":"transparent",borderLeft:selected===ticker?"2px solid #6366f1":"2px solid transparent",transition:"all 0.12s",position:"relative"}}>
                    <div style={{display:"flex",justifyContent:"space-between"}}>
                      <div>
                        <div style={{display:"flex",alignItems:"center",gap:4}}>
                          <span style={{fontSize:12,fontWeight:600,color:selected===ticker?"#a5b4fc":"#e2e8f0"}}>{ticker}</span>
                          {d.live&&<div style={{width:4,height:4,borderRadius:"50%",background:"#22d3a0"}}/>}
                        </div>
                        <div style={{fontSize:9,color:"#334155",marginTop:1}}>{u.sector}</div>
                      </div>
                      <div style={{textAlign:"right"}}>
                        <div style={{fontSize:11,fontWeight:600,fontFamily:"'DM Mono'"}}>${d.price?.toFixed(2)||"--"}</div>
                        <div style={{fontSize:9,color:pos?"#22d3a0":"#f87171",fontFamily:"'DM Mono'"}}>{pos?"▲":"▼"}{Math.abs(d.changePct||0).toFixed(2)}%</div>
                      </div>
                    </div>
                    <div style={{marginTop:4}}>{spark.length>1&&<Sparkline data={spark} positive={pos} width={166} height={18}/>}</div>
                    <div onClick={e=>{e.stopPropagation();removeFromWatchlist(ticker);}} onMouseOver={e=>e.currentTarget.style.opacity="1"} onMouseOut={e=>e.currentTarget.style.opacity="0"} style={{position:"absolute",top:6,right:8,fontSize:9,color:"#475569",cursor:"pointer",opacity:0,transition:"opacity 0.15s"}}>✕</div>
                  </div>
                );
              })}
            </div>
            <div style={{padding:"10px 13px",borderTop:"1px solid #1a2238"}}>
              <button onClick={()=>setView("browser")} style={{width:"100%",background:"linear-gradient(135deg,rgba(99,102,241,0.15),rgba(34,211,160,0.1))",border:"1px solid rgba(99,102,241,0.3)",borderRadius:8,color:"#a5b4fc",padding:"7px",fontSize:11,cursor:"pointer",fontWeight:600,fontFamily:"'DM Sans'"}}>🔍 Browse All 30 Stocks</button>
            </div>
          </div>

          {/* Main Panel */}
          <div style={{flex:1,display:"flex",flexDirection:"column",overflow:"hidden"}}>
            {/* Stock Hero */}
            <div style={{padding:"13px 20px 0",background:"#0a0e1a",borderBottom:"1px solid #1a2238",flexShrink:0}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",flexWrap:"wrap",gap:10}}>
                <div>
                  <div style={{display:"flex",alignItems:"center",gap:8}}>
                    <span style={{fontSize:22,fontWeight:700,letterSpacing:"-1px"}}>{selected}</span>
                    <span style={{fontSize:11,color:"#475569"}}>{selData.name||selUni.name}</span>
                    {selData.live&&<span style={{fontSize:9,background:"rgba(34,211,160,0.15)",color:"#22d3a0",padding:"2px 7px",borderRadius:4,fontFamily:"'DM Mono'",fontWeight:700}}>LIVE · {selData.src}</span>}
                    <span style={{fontSize:9,background:`${RATING_COLOR[selUni.rating]||"#6366f1"}20`,color:RATING_COLOR[selUni.rating]||"#6366f1",padding:"2px 7px",borderRadius:4,fontWeight:700}}>{selUni.rating}</span>
                    <span style={{fontSize:9,background:`${RISK_COLOR[selUni.risk]||"#64748b"}20`,color:RISK_COLOR[selUni.risk]||"#64748b",padding:"2px 7px",borderRadius:4,fontWeight:600}}>Risk: {selUni.risk}</span>
                  </div>
                  <div style={{display:"flex",alignItems:"baseline",gap:10,marginTop:4}}>
                    <span style={{fontSize:30,fontWeight:700,fontFamily:"'DM Mono'",letterSpacing:"-1px"}}>${selData.price?.toFixed(2)||"--"}</span>
                    <span style={{fontSize:13,fontWeight:600,fontFamily:"'DM Mono'",color:isPos?"#22d3a0":"#f87171",background:isPos?"rgba(34,211,160,0.1)":"rgba(248,113,113,0.1)",padding:"2px 8px",borderRadius:4}}>
                      {isPos?"+":""}{selData.change?.toFixed(2)||"0.00"} ({isPos?"+":""}{selData.changePct?.toFixed(2)||"0.00"}%)
                    </span>
                  </div>
                  <div style={{fontSize:10,color:"#64748b",marginTop:4,maxWidth:500,lineHeight:1.4}}>{selUni.why?.slice(0,110)}...</div>
                </div>
                <div style={{display:"flex",gap:14,flexWrap:"wrap"}}>
                  {[["OPEN",selData.open?.toFixed(2)],["HIGH",selData.high?.toFixed(2)],["LOW",selData.low?.toFixed(2)],["PREV",selData.prevClose?.toFixed(2)],["VOL",selData.volume],["MKT CAP",selData.mktCap],["P/E",selData.pe]].map(([l,v])=>(
                    <div key={l}>
                      <div style={{fontSize:8,color:"#334155",fontFamily:"'DM Mono'",letterSpacing:"1px"}}>{l}</div>
                      <div style={{fontSize:11,fontWeight:600,fontFamily:"'DM Mono'",marginTop:2}}>{v||"N/A"}</div>
                    </div>
                  ))}
                </div>
              </div>
              <div style={{display:"flex",gap:0,marginTop:12}}>
                {["chat","market"].map(tab=>(
                  <button key={tab} onClick={()=>setActiveTab(tab)} style={{background:activeTab===tab?"rgba(99,102,241,0.15)":"transparent",border:"none",borderBottom:activeTab===tab?"2px solid #6366f1":"2px solid transparent",color:activeTab===tab?"#a5b4fc":"#475569",padding:"7px 16px",cursor:"pointer",fontSize:11,fontWeight:600,transition:"all 0.15s"}}>
                    {tab==="chat"?"🤖 AI Assistant":"📊 Market Overview"}
                  </button>
                ))}
              </div>
            </div>

            {/* Chat Tab */}
            {activeTab==="chat"&&(
              <div style={{flex:1,display:"flex",flexDirection:"column",overflow:"hidden"}}>
                <div style={{flex:1,overflowY:"auto",padding:"14px 20px",display:"flex",flexDirection:"column",gap:10}}>
                  {messages.map((msg,i)=>(
                    <div key={i} style={{display:"flex",justifyContent:msg.role==="user"?"flex-end":"flex-start",animation:"fadein 0.25s ease"}}>
                      {msg.role==="assistant"&&<div style={{width:26,height:26,borderRadius:7,background:"linear-gradient(135deg,#6366f1,#22d3a0)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:11,marginRight:7,flexShrink:0,alignSelf:"flex-start",marginTop:2}}>🤖</div>}
                      <div style={{maxWidth:"74%",padding:"9px 13px",borderRadius:msg.role==="user"?"12px 12px 3px 12px":"12px 12px 12px 3px",background:msg.role==="user"?"linear-gradient(135deg,#6366f1,#4f46e5)":"#111827",fontSize:12,lineHeight:1.65,color:msg.role==="user"?"#fff":"#cbd5e1",whiteSpace:"pre-wrap",border:msg.role==="assistant"?"1px solid #1a2238":"none"}}>
                        {msg.content}
                      </div>
                    </div>
                  ))}
                  {chatLoading&&(
                    <div style={{display:"flex",alignItems:"center",gap:7}}>
                      <div style={{width:26,height:26,borderRadius:7,background:"linear-gradient(135deg,#6366f1,#22d3a0)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:11}}>🤖</div>
                      <div style={{background:"#111827",padding:"9px 13px",borderRadius:"12px 12px 12px 3px",border:"1px solid #1a2238"}}>
                        <div style={{display:"flex",gap:4}}>{[0,1,2].map(i=><div key={i} style={{width:5,height:5,borderRadius:"50%",background:"#6366f1",animation:`bounce 1.2s ${i*0.2}s infinite`}}/>)}</div>
                      </div>
                    </div>
                  )}
                  <div ref={chatEndRef}/>
                </div>
                <div style={{padding:"0 20px 7px",display:"flex",gap:5,flexWrap:"wrap"}}>
                  {quickPrompts.map((p,i)=>(
                    <button key={i} onClick={()=>sendMessage(p)} className="btn-hover" style={{background:"rgba(99,102,241,0.08)",border:"1px solid rgba(99,102,241,0.2)",borderRadius:16,color:"#818cf8",padding:"3px 11px",fontSize:10,cursor:"pointer",transition:"all 0.15s"}}>{p}</button>
                  ))}
                </div>
                <div style={{padding:"8px 20px 14px",borderTop:"1px solid #1a2238",display:"flex",gap:9}}>
                  <input value={input} onChange={e=>setInput(e.target.value)} onKeyDown={e=>e.key==="Enter"&&!e.shiftKey&&sendMessage()} placeholder={`Ask about ${selected}, compare stocks, build a portfolio...`} disabled={chatLoading} style={{flex:1,background:"#0d1326",border:"1px solid #1e293b",borderRadius:9,padding:"9px 13px",color:"#e2e8f0",fontSize:12,outline:"none",fontFamily:"'DM Sans'"}}/>
                  <button onClick={()=>sendMessage()} disabled={chatLoading||!input.trim()} className="btn-hover" style={{background:chatLoading||!input.trim()?"#0d1326":"linear-gradient(135deg,#6366f1,#4f46e5)",border:"none",borderRadius:9,color:chatLoading||!input.trim()?"#334155":"white",width:42,cursor:chatLoading||!input.trim()?"not-allowed":"pointer",fontSize:16,transition:"all 0.15s"}}>➤</button>
                </div>
              </div>
            )}

            {/* Market Tab */}
            {activeTab==="market"&&(
              <div style={{flex:1,display:"flex",flexDirection:"column",overflow:"hidden"}}>
                <div style={{padding:"10px 20px",borderBottom:"1px solid #1a2238",display:"flex",gap:5,flexWrap:"wrap",flexShrink:0}}>
                  {Object.entries(CATS).map(([k,v])=>(
                    <button key={k} onClick={()=>setActiveCat(k)} className="btn-hover" style={{background:activeCat===k?`${v.color}22`:"transparent",border:`1px solid ${activeCat===k?v.color:"#1e293b"}`,borderRadius:16,color:activeCat===k?v.color:"#475569",padding:"3px 11px",fontSize:10,cursor:"pointer",fontWeight:600,transition:"all 0.15s"}}>
                      {v.emoji} {v.label}
                    </button>
                  ))}
                </div>
                <div style={{flex:1,overflowY:"auto",padding:"12px 20px"}}>
                  <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(260px,1fr))",gap:9}}>
                    {Object.keys(UNIVERSE).filter(t=>activeCat==="all"||UNIVERSE[t].cat===activeCat).map(ticker=>{
                      const d=prices[ticker]||{price:UNIVERSE[ticker].seed,change:0,changePct:0};
                      const u=UNIVERSE[ticker];
                      const pos=(d.changePct||0)>=0;
                      const spark=sparklines.current[ticker]||[];
                      const inWatch=watchlist.includes(ticker);
                      return(
                        <div key={ticker} className="card-hover" onClick={()=>{setSelected(ticker);setActiveTab("chat");}} style={{background:"#0a0e1a",border:`1px solid ${selected===ticker?"#6366f1":"#1a2238"}`,borderRadius:11,padding:"12px 13px",cursor:"pointer"}}>
                          <div style={{display:"flex",justifyContent:"space-between",marginBottom:6}}>
                            <div>
                              <div style={{display:"flex",alignItems:"center",gap:5}}>
                                <span style={{fontSize:13,fontWeight:700}}>{ticker}</span>
                                {d.live&&<div style={{width:4,height:4,borderRadius:"50%",background:"#22d3a0"}}/>}
                                <span style={{fontSize:8,background:`${RATING_COLOR[u.rating]}22`,color:RATING_COLOR[u.rating],padding:"1px 5px",borderRadius:3,fontWeight:700}}>{u.rating}</span>
                              </div>
                              <div style={{fontSize:9,color:"#334155",marginTop:1}}>{u.sector}</div>
                            </div>
                            <div style={{textAlign:"right"}}>
                              <div style={{fontSize:14,fontWeight:700,fontFamily:"'DM Mono'"}}>${d.price?.toFixed(2)}</div>
                              <div style={{fontSize:10,color:pos?"#22d3a0":"#f87171",fontFamily:"'DM Mono'"}}>{pos?"▲":"▼"} {Math.abs(d.changePct||0).toFixed(2)}%</div>
                            </div>
                          </div>
                          {spark.length>1&&<Sparkline data={spark} positive={pos} width={232} height={26}/>}
                          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginTop:7}}>
                            <span style={{fontSize:9,color:"#475569",fontFamily:"'DM Mono'"}}>Risk: <span style={{color:RISK_COLOR[u.risk]}}>{u.risk}</span></span>
                            <button onClick={e=>{e.stopPropagation();inWatch?removeFromWatchlist(ticker):addToWatchlist(ticker);}} style={{fontSize:9,fontWeight:600,padding:"2px 8px",borderRadius:5,border:"none",cursor:"pointer",background:inWatch?"rgba(248,113,113,0.15)":"rgba(34,211,160,0.15)",color:inWatch?"#f87171":"#22d3a0"}}>
                              {inWatch?"− Remove":"+ Watch"}
                            </button>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  );
}
